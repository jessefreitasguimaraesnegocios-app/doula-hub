# Optional: unlock /admin when Supabase env vars are not set (exposed in the client bundle — dev/staging only).
VITE_ADMIN_PASSWORD=

# Supabase (site_settings, doulas, shop_products, Storage bucket `doulas`). Create a user in Authentication for /admin.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- SMTP (Gmail app password) — servidor apenas (NUNCA prefixo VITE_) ---
# SMTP_USER / SMTP_PASS (ou EMAIL_USER / EMAIL_PASS)
# SMTP_ACTION_SECRET — obrigatório para o botão «Enviar teste» no admin
# SMTP_FROM_NAME=All Things Babies
# SMTP_NOTIFY_TO= — cópias do formulário de contacto (predef.: mesmo que SMTP_USER)
# SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
# DISABLE_SMTP_SENDS=1 — desliga envios
