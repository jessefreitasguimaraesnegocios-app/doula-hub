# Optional: unlock /admin when Supabase env vars are not set (exposed in the client bundle — dev/staging only).
VITE_ADMIN_PASSWORD=

# Supabase (site_settings, doulas, shop_products, Storage bucket `doulas`). Create a user in Authentication for /admin.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only: gravar marcações (/booking → booking_requests) e atualizar Google no CRM. Nunca VITE_.
# Se omitir, o fluxo de marcação continua (Calendar/e-mail), mas o mini-CRM no /admin não grava linhas.
SUPABASE_SERVICE_ROLE_KEY=
# Opcional se já tens VITE_SUPABASE_URL (alguns deploys usam só esta no servidor)
SUPABASE_URL=

# Google Calendar + Meet (service account). Opcional; sem isto não há evento automático.
# GOOGLE_SERVICE_ACCOUNT_EMAIL=...@....iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_CALENDAR_ID=primary  ou id@group.calendar.google.com
# BOOKING_CALENDAR_TIMEZONE=America/New_York

# --- SMTP (Gmail app password) — servidor apenas (NUNCA prefixo VITE_) ---
# SMTP_USER / SMTP_PASS (ou EMAIL_USER / EMAIL_PASS)
# SMTP_ACTION_SECRET — obrigatório para o botão «Enviar teste» no admin
# SMTP_FROM_NAME=All Things Babies
# SMTP_NOTIFY_TO= — cópias do formulário de contacto (predef.: mesmo que SMTP_USER)
# SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
# DISABLE_SMTP_SENDS=1 — desliga envios
